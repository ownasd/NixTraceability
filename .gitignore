## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleasePublic/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/lib/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# xUnit
TestResults/

# Visual Studio Analyzer
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Profiling Data
*.nmw
*.prof

# CoreClick
*.pfx
*.publishsettings

# Stage marker files
*.deployed

# Node.js
node_modules/
npm-debug.log

# Package management
packages/
# NuGet Restore
project.lock.json
project.fragment.lock.json
artifacts/

# JetBrains Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode
.JustCode/

# TeamCity
_TeamCity*/

# Libs
lib/

# Backup and temporary files from editing tools
*~
*.bak
*.cache
*.ilk
*.log
*.pdb
*.sbr
*.swp
*.tmp

# SQLite database files
*.db
*.db-journal
*.db-shm
*.db-wal

# SQL Server files
*.mdf
*.ldf
*.sdf

# Others
ClientBin/
~$*
*.[Cc]ache
![Dd]efault.[Cc]ache
*.ipa
*.apk
*.vix
*.vixlib

# Publish results
Publish/

<Window x:Class="NixTraceability.SettingsForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" MinHeight="650" MinWidth="900" WindowState="Maximized"
        Icon="Resources/app_icon.png"
        Background="{DynamicResource AppBackgroundBrush}" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ModernTabItemHeader" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" CornerRadius="5" Margin="10,0,10,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Left" ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="TextBlock" x:Key="Header1">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="LabelText">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Background -->
        <Border Grid.Column="0" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"/>
        
        <TabControl Grid.Column="0" Grid.ColumnSpan="2" Background="Transparent" BorderThickness="0" TabStripPlacement="Left">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Width" Value="260"/>
                    <Setter Property="Margin" Value="0,60,0,0"/> 
                </Style>
            </TabControl.Resources>

            <!-- General Tab -->
            <TabItem Header="⚙️ General" Style="{StaticResource ModernTabItemHeader}">
                <Border Background="Transparent" Padding="40" Margin="10,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="General Settings" Style="{StaticResource Header1}"/>
                        
                        <TextBlock Text="Station Name" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="txtStationName" Text="DICV CCU CHILD PARTS TRACEABILITY" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10" FontSize="16" Margin="0,0,0,20"/>

                        <TextBlock Text="Operator Mode" Style="{StaticResource LabelText}"/>
                        <ComboBox x:Name="cmbOperatorMode" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10" FontSize="16" Margin="0,0,0,20">
                            <ComboBoxItem Content="Single Operator" IsSelected="True"/>
                            <ComboBoxItem Content="Dual Operator Validation"/>
                        </ComboBox>

                        <TextBlock Text="Duplicate Check Scope" Style="{StaticResource LabelText}"/>
                        <ComboBox x:Name="cmbDuplicateScope" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10" FontSize="16" Margin="0,0,0,20">
                            <ComboBoxItem Content="Sequence Only" IsSelected="True"/>
                            <ComboBoxItem Content="Whole Day"/>
                            <ComboBoxItem Content="Whole Month"/>
                        </ComboBox>

                        <!-- Company Logo -->
                        <TextBlock Text="Company Logo (Display on Dashboard)" Style="{StaticResource LabelText}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtLogoPath" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10" FontSize="14" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="📂 Browse" Width="100" Height="40" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="5,0,0,0" Click="btnBrowseLogo_Click"/>
                            <Button Grid.Column="2" Content="✖" Width="40" Height="40" Background="#DC3545" Foreground="White" BorderThickness="0" Margin="5,0,0,0" Click="btnClearLogo_Click"/>
                        </Grid>
                        <Image x:Name="imgLogoPreview" Height="60" Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,0,20" Visibility="Collapsed"/>

                        <!-- Product / Assembly Reference Image -->
                        <TextBlock Text="📦  Product / Assembly Image (Display on Scan Screen)" Style="{StaticResource LabelText}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="This is the image of the final assembled product shown to operators during scanning."
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtProductImagePath" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10" FontSize="14" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="📂 Browse" Width="100" Height="40" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="5,0,0,0" Click="btnBrowseProductImage_Click"/>
                            <Button Grid.Column="2" Content="✖" Width="40" Height="40" Background="#DC3545" Foreground="White" BorderThickness="0" Margin="5,0,0,0" Click="btnClearProductImage_Click"/>
                        </Grid>
                        <Image x:Name="imgProductPreview" Height="80" Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,0,20" Visibility="Collapsed"/>

                        <Button x:Name="btnSaveGeneral" Content="💾 Save General Settings" Width="220" Height="45" HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Click="btnSaveGeneral_Click" Margin="0,10,0,0" FontSize="16"/>
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- Appearance Tab -->
            <TabItem Header="🎨 Appearance" Style="{StaticResource ModernTabItemHeader}">
                <Border Background="Transparent" Padding="40" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Appearance Settings" Style="{StaticResource Header1}"/>
                        
                        <TextBlock Text="App Theme" Style="{StaticResource LabelText}"/>
                        <ComboBox x:Name="cmbTheme" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10" FontSize="16" Margin="0,0,0,20" SelectionChanged="cmbTheme_SelectionChanged">
                            <ComboBoxItem Content="Dark Theme" IsSelected="True"/>
                            <ComboBoxItem Content="Light Theme"/>
                        </ComboBox>

                        <!-- OK Sound -->
                        <TextBlock Text="OK Scan Sound (WAV file)" Style="{StaticResource LabelText}"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtOkSoundPath" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="8" FontSize="14" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="📂 Browse" Width="90" Height="38" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="5,0,0,0" Click="btnBrowseOkSound_Click"/>
                            <Button Grid.Column="2" Content="✖" Width="38" Height="38" Background="#DC3545" Foreground="White" BorderThickness="0" Margin="5,0,0,0" Click="btnClearOkSound_Click"/>
                        </Grid>

                        <!-- NG Sound -->
                        <TextBlock Text="NG / Error Sound (WAV file)" Style="{StaticResource LabelText}"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtNgSoundPath" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="8" FontSize="14" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="📂 Browse" Width="90" Height="38" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="5,0,0,0" Click="btnBrowseNgSound_Click"/>
                            <Button Grid.Column="2" Content="✖" Width="38" Height="38" Background="#DC3545" Foreground="White" BorderThickness="0" Margin="5,0,0,0" Click="btnClearNgSound_Click"/>
                        </Grid>

                        <Button x:Name="btnSaveAppearance" Content="💾 Save Appearance &amp; Audio" Width="230" Height="45" HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Click="btnSaveAppearance_Click" Margin="0,10,0,0" FontSize="16"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Traceability Tab -->
            <TabItem Header="🔍 Traceability Parts" Style="{StaticResource ModernTabItemHeader}">
                <Border Background="Transparent" Padding="40" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Add / Modify Traceability Parts" Style="{StaticResource Header1}"/>

                        <!-- Add Part Form -->
                        <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,15,15">
                                        <TextBlock Text="Part Name:" Style="{StaticResource LabelText}"/>
                                        <TextBox x:Name="txtNewPartName" Height="38" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="8,0" FontSize="15"/>
                                    </StackPanel>
                                    <StackPanel Margin="15,0,0,15">
                                        <TextBlock Text="Part Code:" Style="{StaticResource LabelText}"/>
                                        <TextBox x:Name="txtNewPartCode" Height="38" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="8,0" FontSize="15"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,15,15">
                                        <TextBlock Text="Validation (Comma-separated for multi):" Style="{StaticResource LabelText}"/>
                                        <TextBox x:Name="txtNewValidation" Height="38" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="8,0" FontSize="15"/>
                                    </StackPanel>
                                    <StackPanel Margin="15,0,0,15">
                                        <TextBlock Style="{StaticResource LabelText}">
                                            <Run Text="QR Length Validation"/>
                                            <Run Text=" (0 = unlimited, e.g. 20 = exactly 20 chars)" Foreground="#888888" FontSize="13"/>
                                        </TextBlock>
                                        <TextBox x:Name="txtNewScanLimit" Height="38"
                                                 Background="{DynamicResource ControlBackgroundBrush}"
                                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                                 BorderBrush="{DynamicResource BorderBrush}"
                                                 Padding="8,0" FontSize="15" Text="0"
                                                 ToolTip="Enter 0 for no length check. Enter any number (e.g. 18) to allow ONLY that exact character count."/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,15,15">
                                        <TextBlock Text="Row Sequence:" Style="{StaticResource LabelText}"/>
                                        <TextBox x:Name="txtNewSequence" Height="38" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="8,0" FontSize="15"/>
                                    </StackPanel>
                                    <StackPanel Margin="15,0,0,15">
                                        <TextBlock Text="Custom Firebase Node (Optional):" Style="{StaticResource LabelText}"/>
                                        <TextBox x:Name="txtNewFirebaseNode" Height="38" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="8,0" FontSize="15"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,15,0">
                                        <TextBlock Text="Check Duplicates:" Style="{StaticResource LabelText}"/>
                                        <CheckBox x:Name="chkNewCheckDuplicate" Content="Enable Duplicacy Validation" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,8,0,0" IsChecked="True" FontSize="15"/>
                                    </StackPanel>
                                    <StackPanel Margin="15,0,0,0">
                                        <TextBlock Text="Part Image (Optional):" Style="{StaticResource LabelText}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="txtNewImagePath" Height="38" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="8,0" FontSize="13" IsReadOnly="True"/>
                                            <Button Grid.Column="1" Content="📂" Width="38" Height="38" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="4,0,0,0" Click="btnBrowsePartImage_Click"/>
                                            <Button x:Name="btnSetQrArea" Grid.Column="2" Content="📍 Set QR Area" Height="38" Padding="10,0" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Margin="4,0,0,0" Click="btnSetQrArea_Click"/>
                                        </Grid>
                                        <TextBox x:Name="txtNewQrRect" Visibility="Collapsed"/>
                                    </StackPanel>
                                </UniformGrid>
                                <Button x:Name="btnAddPart" Content="➕ Add Part" Width="140" Height="38" Margin="0,15,0,0" HorizontalAlignment="Right" Click="btnAddPart_Click" Background="#28A745" Foreground="White" BorderThickness="0" FontSize="15"/>
                            </StackPanel>
                        </Border>

                        <DataGrid x:Name="dgParts" Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" 
                                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" AutoGenerateColumns="False" CanUserAddRows="False"
                                  RowBackground="{DynamicResource DataGridRowBackground}" AlternatingRowBackground="{DynamicResource DataGridAltRowBackground}"
                                  GridLinesVisibility="All" HorizontalGridLinesBrush="{DynamicResource DataGridGridLines}" VerticalGridLinesBrush="{DynamicResource DataGridGridLines}"
                                  HeadersVisibility="Column" RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Part Name" Binding="{Binding PartName}" Width="2*"/>
                                <DataGridTextColumn Header="Part Code" Binding="{Binding PartCode}" Width="2*"/>
                                <DataGridTextColumn Header="Validation" Binding="{Binding ValidationText}" Width="*"/>
                                <DataGridTextColumn Header="FB Node" Binding="{Binding FirebaseValidationNode}" Width="*"/>
                                <DataGridTextColumn Header="QR Length" Binding="{Binding ScanLengthLimit}" Width="80"/>
                                <DataGridTextColumn Header="Seq." Binding="{Binding Sequence}" Width="50"/>
                                <DataGridCheckBoxColumn Header="Dup" Binding="{Binding CheckDuplicate}" Width="40"/>
                                <DataGridTemplateColumn Header="Actions" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="✏️ Edit" Click="btnEditPart_Click" Background="#007ACC" Foreground="White" BorderThickness="0" Padding="6,3" Margin="5,3,3,3" FontSize="13"/>
                                                <Button Content="🗑️ Del" Click="btnDeletePart_Click" Background="#DC3545" Foreground="White" BorderThickness="0" Padding="6,3" Margin="0,3,5,3" FontSize="13"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
            
            <!-- System / Database Tab -->
            <TabItem Header="📂 Data / Backup" Style="{StaticResource ModernTabItemHeader}">
                <Border Background="Transparent" Padding="40" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Data &amp; Backup Settings" Style="{StaticResource Header1}"/>
                        
                        <TextBlock Text="Data Export Path" Style="{StaticResource LabelText}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBox x:Name="txtExportPath" Text="C:\Exports\" Width="400" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10" FontSize="14"/>
                            <Button Content="..." Width="40" Height="40" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0" Margin="10,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Auto-Backup Database" Style="{StaticResource LabelText}"/>
                        <CheckBox x:Name="chkAutoBackup" Content="Enable daily automatic backup" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="14" Margin="0,0,0,20" IsChecked="True"/>

                        <TextBlock Text="Firebase Sync Integration" Style="{StaticResource Header1}" FontSize="24" Margin="0,10,0,20"/>
                        
                        <CheckBox x:Name="chkFirebaseSync" Content="Enable Real-Time Firebase Sync" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="16" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Firebase Database URl (e.g., https://your-project.firebaseio.com/)" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="txtFirebaseUrl" Width="500" HorizontalAlignment="Left" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10" FontSize="14" Margin="0,0,0,20"/>

                        <TextBlock Text="Sub-Assembly PCBA Validation" Style="{StaticResource Header1}" FontSize="20" Margin="0,10,0,15"/>
                        
                        <CheckBox x:Name="chkFirebaseValidation" Content="Enable Firebase Validation for PCBA" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="16" Margin="0,0,0,10"/>
                        
                        <TextBlock Text="Validation Node (e.g., IR PCBA SUB ASSy)" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="txtFirebaseValidationNode" Width="500" HorizontalAlignment="Left" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10" FontSize="14" Margin="0,0,0,20"/>

                        <!-- Test Firebase Validation -->
                        <Border Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🔬  Test Firebase Validation" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>
                                <TextBlock Text="Enter a barcode that was scanned in Nixirtrace to verify the connection works correctly:" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtTestBarcode" Height="38" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10,0" FontSize="15" VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="1" x:Name="btnTestFirebase" Content="🔍 Test Lookup" Height="38" Padding="15,0" Background="#007ACC" Foreground="White" BorderThickness="0" Margin="10,0,0,0" FontSize="14" Click="btnTestFirebase_Click"/>
                                </Grid>
                                <Border x:Name="borderTestResult" Background="#1a1a2e" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Visibility="Collapsed">
                                    <TextBlock x:Name="txtTestResult" FontSize="13" Foreground="#00ff88" TextWrapping="Wrap" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Button x:Name="btnSaveDataSettings" Content="💾 Save Data Settings" Width="200" Height="40" HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Click="btnSaveDataSettings_Click" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
        
        <!-- Absolute Title overlay on the Sidebar -->
        <TextBlock Grid.Column="0" Text="Settings" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="22" FontWeight="Bold" Margin="30,20,0,0" IsHitTestVisible="False"/>

        <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Margin="10,0,10,20">
            <Button x:Name="btnSaveAllSettings" Content="💾 Save All Settings" Height="40" Margin="0,0,0,10" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Click="btnSaveAllSettings_Click"/>
            <Button x:Name="btnHome" Content="🏠 Home" Height="40" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0" Click="btnHome_Click"/>
        </StackPanel>
    </Grid>
</Window>

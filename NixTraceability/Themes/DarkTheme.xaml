<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Brushes -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#252526"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#2D2D30"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#1E1E1E"/>
    
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="White"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
    
    <SolidColorBrush x:Key="NavButtonHoverBackground" Color="#3E3E42"/>
    <SolidColorBrush x:Key="NavButtonHoverForeground" Color="White"/>

    <!-- Specific Brushes -->
    <SolidColorBrush x:Key="OkTextBrush" Color="#66FF99"/>
    <SolidColorBrush x:Key="NgTextBrush" Color="#FF6666"/>
    <SolidColorBrush x:Key="OkBackgroundBrush" Color="#1E3224"/>
    <SolidColorBrush x:Key="NgBackgroundBrush" Color="#3A1D1D"/>
    
    <!-- DataGrid Colors -->
    <SolidColorBrush x:Key="DataGridHeaderBackground" Color="#2D2D30"/>
    <SolidColorBrush x:Key="DataGridHeaderForeground" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="DataGridRowBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="DataGridAltRowBackground" Color="#252526"/>
    <SolidColorBrush x:Key="DataGridGridLines" Color="#3E3E42"/>
</ResourceDictionary>

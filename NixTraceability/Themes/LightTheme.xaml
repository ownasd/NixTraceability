<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light Theme Brushes -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
    
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#4B5563"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
    
    <SolidColorBrush x:Key="NavButtonHoverBackground" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="NavButtonHoverForeground" Color="#111827"/>

    <!-- Specific Brushes -->
    <SolidColorBrush x:Key="OkTextBrush" Color="#15803D"/>
    <SolidColorBrush x:Key="NgTextBrush" Color="#B91C1C"/>
    <SolidColorBrush x:Key="OkBackgroundBrush" Color="#DCFCE7"/>
    <SolidColorBrush x:Key="NgBackgroundBrush" Color="#FEE2E2"/>
    
    <!-- DataGrid Colors -->
    <SolidColorBrush x:Key="DataGridHeaderBackground" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="DataGridHeaderForeground" Color="#374151"/>
    <SolidColorBrush x:Key="DataGridRowBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DataGridAltRowBackground" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="DataGridGridLines" Color="#D1D5DB"/>
</ResourceDictionary>

<Window x:Class="NixTraceability.ScanForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NixTraceability"
        mc:Ignorable="d"
        Title="NixTraceability - Dynamic Scan" MinHeight="600" MinWidth="800" WindowState="Maximized"
        Icon="Resources/app_icon.png"
        Background="{DynamicResource AppBackgroundBrush}" WindowStartupLocation="CenterScreen">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <Border Grid.Row="0" Margin="10,10,10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Date -->
                <TextBlock x:Name="lblDate" Text="28/03/2026" Foreground="White" FontSize="22" FontWeight="Bold"
                           Background="{DynamicResource AccentBrush}" Padding="15,8" VerticalAlignment="Stretch"/>

                <!-- Station Title -->
                <TextBlock Grid.Column="1" x:Name="lblStationName" Text="DICV CCU CHILD PARTS TRACEABILITY"
                           Foreground="White" Background="{DynamicResource AccentBrush}" FontSize="22"
                           FontWeight="Bold" TextAlignment="Center" Padding="15,8" Margin="4,0" VerticalAlignment="Stretch"
                           TextWrapping="NoWrap" TextTrimming="None"/>

                <!-- Time -->
                <TextBlock x:Name="lblTime" Grid.Column="2" Text="10:00:00 AM" Foreground="White" FontSize="22"
                           FontWeight="Bold" Background="{DynamicResource AccentBrush}" Padding="15,8"
                           Margin="0,0,4,0" VerticalAlignment="Stretch"/>

                <!-- Shift Selector -->
                <Border Grid.Column="3" Background="{DynamicResource ControlBackgroundBrush}" Margin="0,0,4,0" Padding="8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Shift:" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"
                                   FontWeight="Bold" Margin="0,0,6,0" FontSize="16"/>
                        <ComboBox x:Name="cmbShift" Width="120" FontSize="16" FontWeight="Bold" Height="34"
                                  VerticalContentAlignment="Center" Background="{DynamicResource PanelBackgroundBrush}"
                                  Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBoxItem Content="Morning" IsSelected="True"/>
                            <ComboBoxItem Content="Evening"/>
                            <ComboBoxItem Content="Night"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Batch Number -->
                <Border Grid.Column="4" Background="{DynamicResource ControlBackgroundBrush}" Margin="0,0,4,0" Padding="8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Batch:" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"
                                   FontWeight="Bold" Margin="0,0,6,0" FontSize="16"/>
                        <TextBox x:Name="txtBatch" Width="110" FontSize="16" FontWeight="Bold" Height="34"
                                 VerticalContentAlignment="Center" Background="{DynamicResource PanelBackgroundBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                 Text="B001"/>
                    </StackPanel>
                </Border>

                <!-- Operator ID -->
                <Border Grid.Column="5" Background="{DynamicResource ControlBackgroundBrush}" Margin="0,0,4,0" Padding="8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Operator:" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"
                                   FontWeight="Bold" Margin="0,0,6,0" FontSize="16"/>
                        <TextBox x:Name="txtOperatorId" Width="90" Text="OP-01" FontSize="16" FontWeight="Bold" Height="34"
                                 VerticalContentAlignment="Center" Background="{DynamicResource PanelBackgroundBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Home Button -->
                <Button x:Name="btnHome" Grid.Column="6" Content="🏠 Home" Background="{DynamicResource OkBackgroundBrush}"
                        Foreground="{DynamicResource OkTextBrush}" FontSize="18" FontWeight="Bold" Padding="15,8"
                        BorderThickness="0" Click="btnHome_Click"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Scanning Area -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
                <StackPanel>
                    <StackPanel x:Name="partsContainer" Background="Transparent"/>
                    <TextBlock x:Name="lblOverallStatus" Text="" Foreground="{DynamicResource OkTextBrush}"
                               FontSize="20" FontWeight="Bold" Margin="0,10,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Image Area — Split into Product (top) and Part (bottom) -->
            <Border Grid.Column="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Background="{DynamicResource PanelBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TOP: Product / Assembly Image (static for the session) -->
                    <Grid Grid.Row="0">
                        <Border Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📦" FontSize="40" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="txtProductPlaceholder" Text="Product Image"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <Image x:Name="productImage" Stretch="Uniform" Margin="12"/>
                            </Grid>
                        </Border>
                        <Border VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                Background="#CC1A1A2E" Padding="10,4">
                            <TextBlock Text="🏭  PRODUCT" Foreground="White" FontSize="13"
                                       FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Divider -->
                    <Border Grid.Row="1" Height="2" Background="{DynamicResource BorderBrush}"/>

                    <!-- BOTTOM: Part Reference Image (changes per scan row) -->
                    <Grid Grid.Row="2">
                        <Border Background="{DynamicResource AppBackgroundBrush}">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🔩" FontSize="36" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="txtImagePlaceholder" Text="Part Image"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <Image x:Name="partImage" Stretch="Uniform" Margin="12"/>
                            </Grid>
                        </Border>
                        <Border VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                Background="#CC1A2E1A" Padding="10,4">
                            <TextBlock x:Name="lblCurrentPartName" Text="🔩  PART" Foreground="White"
                                       FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource AccentBrush}" Padding="10" Margin="10,0,10,10">
            <TextBlock x:Name="lblFooter" Text="SCAN THE BARCODE" Foreground="White" FontSize="22"
                       FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <!-- Hidden reset button -->
        <Button x:Name="btnReset" Visibility="Collapsed" Click="btnReset_Click"/>
    </Grid>
</Window>
